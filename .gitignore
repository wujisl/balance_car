# Ignore every repository-root entry by default.
/*

# Keep only project source directories and required configuration files.
# NOTE: .vscode/ is intentionally ignored to avoid syncing personal IDE settings.
!/doc/
!/doc/**
!/tool/
!/tool/**
# Runtime speed telemetry recordings produced by the host application.
/tool/records/
# Runtime I2C diagnostics and locally generated camera calibration results.
/tool/log/
/tool/calibration/output/
/tool/**/__pycache__/
!/include/
!/include/**
!/lib/
!/lib/**
!/src/
!/src/**
!/test/
!/test/**
!/.gitignore
!/platformio.ini
